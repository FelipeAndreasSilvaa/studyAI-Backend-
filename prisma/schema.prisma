generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String      @id @default(cuid())
  name       String
  email      String      @unique
  password   String
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  chats      Chat[]
  documents  Document[]
  flashcards Flashcard[]
  quizzes    Quiz[]
  roadmaps Roadmap[]

  @@map("users")
}

model Chat {
  id        String    @id @default(cuid())
  userId    String
  title     String?
  summary   String?   @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([userId])
  @@map("chats")
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  role      MessageRole
  content   String      @db.Text
  model     String?
  tokens    Int?
  metadata  Json?
  createdAt DateTime    @default(now())
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@map("messages")
}

model Document {
  id            String          @id @default(cuid())
  userId        String
  title         String
  fileUrl       String
  extractedText String?         @db.Text
  status        DocumentStatus  @default(PROCESSING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks        DocumentChunk[]
  flashcards    Flashcard[]
  summaries     Summary[]
  quizzes       Quiz[]

  @@index([userId])
  @@map("documents")
}

model Summary {
  id String @id @default(cuid())

  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  content   String
  status    SummaryStatus @default(PROCESSING)
  createdAt DateTime      @default(now())

  @@index([documentId])
  @@map("summaries")
}

model DocumentChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkText  String   @db.Text
  index      Int
  embedding  Json?
  metadata   Json?
  createdAt  DateTime @default(now())
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_chunks")
}

model Flashcard {
  id         String    @id @default(cuid())
  userId     String
  documentId String?
  question   String    @db.Text
  answer     String    @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([documentId])
  @@map("flashcards")
}

model Quiz {
  id          String   @id @default(cuid())
  title       String
  description String?
  documentId  String
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  document  Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@index([documentId])
  @@index([userId])
  @@map("quizzes")
}

model QuizQuestion {
  id          String   @id @default(cuid())
  quizId      String
  question    String   @db.Text
  explanation String?  @db.Text
  createdAt   DateTime @default(now())

  quiz         Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  alternatives QuizAlternative[]

  @@index([quizId])
  @@map("quiz_questions")
}

model QuizAlternative {
  id         String  @id @default(cuid())
  questionId String
  text       String  @db.Text
  isCorrect  Boolean

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("quiz_alternatives")
}

model Roadmap {
  id          String        @id @default(cuid())
  userId      String
  title       String
  goal        String        @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       RoadmapStep[]

  @@index([userId])
  @@map("roadmaps")
}

model RoadmapStep {
  id          String         @id @default(cuid())
  roadmapId   String
  title       String
  description String         @db.Text
  duration    String
  order       Int
  status      RoadmapStatus  @default(PENDING)

  roadmap     Roadmap        @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@index([roadmapId])
  @@map("roadmap_steps")
}

enum RoadmapStatus {
  PENDING
  ACTIVE
  COMPLETED
}

enum SummaryStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum DocumentStatus {
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}
